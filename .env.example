# Salin file ini jadi ".env" lalu isi nilainya. JANGAN commit .env asli ke GitHub.

# Kunci rahasia Flask untuk session (isi string acak panjang)
SECRET_KEY=ganti-dengan-string-acak-panjang

# Kredensial Gmail untuk kirim email OTP.
GMAIL_ADDRESS=emailkamu@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# Alamat backend socket (lokal). Ganti kalau server socket di mesin lain.
TCP_FILE_HOST=127.0.0.1
TCP_FILE_PORT=9010
UDP_VIDEO_HOST=127.0.0.1
UDP_VIDEO_PORT=9020
